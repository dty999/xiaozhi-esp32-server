# 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/xiaozhi_next_server"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED=true

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# 文件存储
UPLOAD_DIR="./uploadfile"

# 阿里云 SMS
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# 服务端 WebSocket
WS_PORT=8000
HTTP_PORT=8003

# WebSocket / MQTT 主机地址（设备连接用）
WS_HOST="ws://localhost:8000"
MQTT_ENDPOINT=""

# UDP 音频传输
UDP_PORT=8080
UDP_HOST="0.0.0.0"

# 设备 HMAC 密钥（应与固件编译时的 CONFIG_HMAC_KEY 一致）
DEVICE_HMAC_KEY="xiaozhi-default-hmac-key-change-in-production"

# MCP Vision 配置（可选）
MCP_VISION_URL=""
MCP_VISION_TOKEN=""

# Next.js
NEXT_PUBLIC_APP_NAME="智控台"
